@inject AuthService AuthService
@inject NavigationManager Navigation

<nav class="top-nav" aria-label="주 메뉴">
    <AuthorizeView>
        <Authorized>
            <NavLink class="top-nav-link" href="/live" Match="NavLinkMatch.Prefix">
                <span class="top-nav-icon" aria-hidden="true">●</span>
                <span>실시간</span>
            </NavLink>
            <AuthorizeView Roles="Admin,Operator" Context="_">
                <NavLink class="top-nav-link" href="/history" Match="NavLinkMatch.Prefix">
                    <span class="top-nav-icon" aria-hidden="true">●</span>
                    <span>이력 조회</span>
                </NavLink>
            </AuthorizeView>
            <AuthorizeView Roles="Admin" Context="_">
                <NavLink class="top-nav-link" href="/system-status">
                    <span class="top-nav-icon" aria-hidden="true">●</span>
                    <span>시스템 상태</span>
                </NavLink>
            </AuthorizeView>
            <span class="top-nav-user">
                @AuthService.Username (@AuthService.Role)
            </span>
            <button class="btn btn-sm btn-outline-light ms-2" @onclick="LogoutAsync">로그아웃</button>
        </Authorized>
        <NotAuthorized>
            <NavLink class="top-nav-link" href="/login">로그인</NavLink>
        </NotAuthorized>
    </AuthorizeView>
</nav>

@code {
    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: false);
    }
}
