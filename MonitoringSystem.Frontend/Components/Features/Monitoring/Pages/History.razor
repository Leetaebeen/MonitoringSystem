@page "/history"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Operator")]
@using MonitoringSystem.Shared.Models

<PageTitle>이력 조회</PageTitle>
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>이력 조회</h1>
</div>

<div class="card mb-3 shadow-sm">
    <div class="card-body">
        <div class="row g-3 align-items-end">
            <div class="col-lg-3 col-md-6">
                <label class="form-label text-muted small">시작 일시</label>
                <div class="d-flex gap-2">
                    <input type="date" class="form-control" @bind="_fromDate" />
                    <input type="time" class="form-control" @bind="_fromTime" />
                </div>
            </div>
            
            <div class="col-lg-3 col-md-6">
                <label class="form-label text-muted small">종료 일시</label>
                <div class="d-flex gap-2">
                    <input type="date" class="form-control" @bind="_toDate" />
                    <input type="time" class="form-control" @bind="_toTime" />
                </div>
            </div>

            <div class="col-lg-2 col-md-4">
                <label class="form-label text-muted small">라인 ID</label>
                <input class="form-control" placeholder="예: LINE-A" @bind="_lineIdFilter" />
            </div>

            <div class="col-lg-2 col-md-4">
                <label class="form-label text-muted small">설비 ID</label>
                <input class="form-control" placeholder="예: EQ-001" @bind="_equipmentIdFilter" />
            </div>

            <div class="col-lg-2 col-md-4">
                <label class="form-label text-muted small">페이지 크기</label>
                <select class="form-select" @bind="_pageSize">
                    <option value="20">20개씩 보기</option>
                    <option value="50">50개씩 보기</option>
                    <option value="100">100개씩 보기</option>
                </select>
            </div>

            <div class="col-12 d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                <div class="btn-group">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ApplyQuickRangeAsync(1)">최근 1시간</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ApplyQuickRangeAsync(6)">최근 6시간</button>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="() => ApplyQuickRangeAsync(24)">최근 24시간</button>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-secondary" @onclick="ResetFilterAsync" disabled="@_isLoading">초기화</button>
                    <button class="btn btn-primary px-4" @onclick="ApplyFilterAsync" disabled="@_isLoading">
                        @if (_isLoading) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        조회
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-2 text-muted small">
    <div>
        <span class="me-3"><i class="bi bi-funnel"></i> 조건: <strong>@GetFilterLabel()</strong></span>
        <span><i class="bi bi-list-ol"></i> 총 <strong>@_totalCount.ToString("N0")</strong>건</span>
    </div>
    <div>페이지: <strong>@_page / @Math.Max(_totalPages, 1)</strong></div>
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}

<div class="card shadow-sm mb-3">
    <div class="table-responsive">
        <table class="table table-hover table-striped mb-0 text-center align-middle">
            <thead class="table-light">
                <tr>
                    <th>수집 시각</th>
                    <th>라인</th>
                    <th>설비</th>
                    <th>상태</th>
                    <th>온도 (°C)</th>
                    <th>압력 (bar)</th>
                    <th>진동 (mm/s)</th>
                    <th>RPM</th>
                </tr>
            </thead>
            <tbody>
                @if (_isLoading)
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <div class="spinner-border text-primary mb-2" role="status"></div>
                            <div>데이터를 불러오는 중입니다...</div>
                        </td>
                    </tr>
                }
                else if (!_items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">조회 결과가 없습니다.</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in _items)
                    {
                        <tr>
                            <td class="text-nowrap">@item.LogTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td>@item.LineId</td>
                            <td>@item.EquipmentId</td>
                            <td>
                                <span class="badge @(item.IsAlert ? "bg-danger" : "bg-success")">
                                    @(item.IsAlert ? "경고" : "정상")
                                </span>
                            </td>
                            <td>@item.Temperature.ToString("F1")</td>
                            <td>@item.PressureBar.ToString("F2")</td>
                            <td>@item.VibrationMmS.ToString("F2")</td>
                            <td>@item.Rpm.ToString("N0")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@if (_totalPages > 1)
{
    <div class="d-flex justify-content-center">
        <ul class="pagination">
            <li class="page-item @(_page <= 1 ? "disabled" : "")">
                <button class="page-link" @onclick="PrevPageAsync" disabled="@_isLoading">이전</button>
            </li>
            
            @foreach (var pageNum in GetVisiblePageButtons())
            {
                <li class="page-item @(pageNum == _page ? "active" : "")">
                    <button class="page-link" @onclick="() => GoToPageAsync(pageNum)" disabled="@_isLoading">@pageNum</button>
                </li>
            }
            
            <li class="page-item @(_page >= _totalPages ? "disabled" : "")">
                <button class="page-link" @onclick="NextPageAsync" disabled="@_isLoading">다음</button>
            </li>
        </ul>
    </div>
}

