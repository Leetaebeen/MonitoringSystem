@page "/"
@page "/live"
@rendermode InteractiveServer
@attribute [Authorize]
@using MonitoringSystem.Shared.Models

<PageTitle>실시간 대시보드</PageTitle>

<h1>실시간 대시보드</h1>

<div class="status-bar">
    <span class="badge @GetConnectionBadgeClass()">@_connectionState</span>
    <span>실시간 반영 주기: <strong>5초</strong></span>
    @if (_isLoading)
    {
        <span class="text-secondary">초기 데이터 로딩 중...</span>
    }
</div>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @_errorMessage
    </div>
}

<div class="filter-bar mb-3 d-flex gap-3 align-items-center">
    <div>
        <label class="form-label mb-0 me-2"><strong>라인 필터</strong></label>
        <select class="form-select form-select-sm d-inline-block w-auto" @onchange="OnLineFilterChangedAsync">
            <option value="">전체</option>
            @foreach (var lineId in _availableLineIds)
            {
                <option value="@lineId" selected="@(_selectedLineId == lineId)">@lineId</option>
            }
        </select>
    </div>
    <div>
        <label class="form-label mb-0 me-2"><strong>설비 필터</strong></label>
        <select class="form-select form-select-sm d-inline-block w-auto" @onchange="OnEquipmentFilterChangedAsync">
            <option value="">전체</option>
            @foreach (var equipmentId in _availableEquipmentIds)
            {
                <option value="@equipmentId" selected="@(_selectedEquipmentId == equipmentId)">@equipmentId</option>
            }
        </select>
    </div>
    @if (!string.IsNullOrEmpty(_selectedLineId) || !string.IsNullOrEmpty(_selectedEquipmentId))
    {
        <div>
            <span class="badge bg-primary">
                구독 중: @_currentGroupLabel
            </span>
            <button class="btn btn-sm btn-outline-secondary ms-2" @onclick="ResetFilterAsync">전체 보기</button>
        </div>
    }
</div>

@if (_latestData is null && !_isLoading)
{
    <div class="alert alert-warning" role="alert">
        표시할 센서 데이터가 없습니다.
    </div>
}

<div class="kpi-grid">
    <div class="kpi-card">
        <div class="kpi-label">수신 건수</div>
        <div class="kpi-value">@_recentData.Count</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">알람 건수</div>
        <div class="kpi-value">@AlertCount</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">평균 온도</div>
        <div class="kpi-value">@AverageTemperature.ToString("N1") °C</div>
    </div>
    <div class="kpi-card">
        <div class="kpi-label">평균 진동</div>
        <div class="kpi-value">@AverageVibration.ToString("N1") mm/s</div>
    </div>
</div>

@* 온도·진동 시계열 차트 — SensorChart 컴포넌트(JS Interop) *@
<div class="card mb-3">
    <div class="card-body">
        <h5 class="card-title">온도 / 진동 추이 (최근 @(MaxRows)건)</h5>
        <SensorChart Data="@_recentData" />
    </div>
</div>

@if (_latestData is not null)
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title">최신 스냅샷</h5>
            <div class="snapshot-grid">
                <div><strong>라인</strong><span>@_latestData.LineId</span></div>
                <div><strong>설비</strong><span>@_latestData.EquipmentId (@_latestData.EquipmentType)</span></div>
                <div><strong>온도</strong><span>@_latestData.Temperature °C</span></div>
                <div><strong>압력</strong><span>@_latestData.PressureBar bar</span></div>
                <div><strong>진동</strong><span>@_latestData.VibrationMmS mm/s</span></div>
                <div><strong>RPM</strong><span>@_latestData.Rpm</span></div>
                <div><strong>상태</strong><span>@_latestData.Status (@(_latestData.IsAlert ? "알람" : "정상"))</span></div>
                <div><strong>수집 시각</strong><span>@_latestData.LogTime.ToLocalTime()</span></div>
            </div>
        </div>
    </div>
}

<h4>최근 데이터</h4>
<div class="card">
    <div class="table-responsive">
        <table class="table table-striped table-sm recent-table mb-0">
            <thead>
                <tr>
                    <th>시각</th>
                    <th>라인</th>
                    <th>설비</th>
                    <th>온도(°C)</th>
                    <th>압력(bar)</th>
                    <th>진동(mm/s)</th>
                    <th>RPM</th>
                    <th>상태</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in _recentData)
                {
                    <tr>
                        <td class="time-cell">@item.LogTime.ToLocalTime().ToString("HH:mm:ss")</td>
                        <td>@item.LineId</td>
                        <td>@item.EquipmentId</td>
                        <td>@item.Temperature.ToString("N1")</td>
                        <td>@item.PressureBar.ToString("N2")</td>
                        <td>@item.VibrationMmS.ToString("N2")</td>
                        <td>@item.Rpm</td>
                        <td><span class="badge @(item.IsAlert ? "bg-danger" : "bg-success")">@item.Status</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

