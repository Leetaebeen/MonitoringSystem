@*
    Blazor ↔ JavaScript Interop 예제 컴포넌트

    핵심 개념:
    - IJSRuntime.InvokeAsync<IJSObjectReference>("import", path) → ES 모듈 동적 import
    - OnAfterRenderAsync(firstRender=true) → DOM이 완성된 뒤 JS 초기화
    - OnParametersSetAsync → 부모가 새 데이터를 내려줄 때마다 차트 업데이트
    - IAsyncDisposable → 컴포넌트 제거 시 Chart.js 인스턴스 해제
*@
@using MonitoringSystem.Shared.Models
@inject IJSRuntime JS
@implements IAsyncDisposable

<div style="position: relative; height: 280px;">
    <canvas id="@_canvasId"></canvas>
</div>

@code {
    /// <summary>표시할 센서 데이터 목록. 부모(LiveDashboard)가 내려준다.</summary>
    [Parameter, EditorRequired]
    public IReadOnlyList<SensorData> Data { get; set; } = [];

    // 캔버스 id — 한 페이지에 여러 차트가 있어도 충돌하지 않도록 GUID 사용
    private readonly string _canvasId = $"sc-{Guid.NewGuid():N}";

    // JS 모듈 참조 (sensorChart.js)
    private IJSObjectReference? _module;

    // true가 된 뒤부터 OnParametersSetAsync에서 차트를 업데이트함
    private bool _initialized;

    /// <summary>
    /// Blazor가 DOM을 구성한 직후 호출됨.
    /// firstRender=true 일 때만 JS 모듈을 import하고 차트를 초기 렌더링한다.
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // ES 모듈 import → _module로 JS 함수를 C#에서 직접 호출 가능
        _module = await JS.InvokeAsync<IJSObjectReference>(
            "import", "./js/sensorChart.js");

        await DrawAsync();
        _initialized = true;
    }

    /// <summary>
    /// 부모 컴포넌트가 렌더링될 때마다 호출됨.
    /// 초기화 전에는 아무것도 하지 않고, 이후에는 최신 Data로 차트를 갱신한다.
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        if (!_initialized || _module is null) return;
        await DrawAsync();
    }

    private async Task DrawAsync()
    {
        // 차트는 시간 오름차순(왼쪽 = 과거, 오른쪽 = 최신)으로 표시
        var sorted = Data.OrderBy(x => x.LogTime).ToList();

        var labels = sorted.Select(x => x.LogTime.ToLocalTime().ToString("HH:mm:ss")).ToArray();
        var temps  = sorted.Select(x => (object)x.Temperature).ToArray();
        var vibs   = sorted.Select(x => (object)x.VibrationMmS).ToArray();

        // JS 모듈의 renderChart 함수 호출
        await _module!.InvokeVoidAsync("renderChart", _canvasId, labels, temps, vibs);
    }

    /// <summary>컴포넌트가 페이지에서 제거될 때 Chart.js 인스턴스를 메모리에서 해제한다.</summary>
    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try
            {
                await _module.InvokeVoidAsync("destroyChart", _canvasId);
            }
            catch
            {
                // 이미 연결이 끊긴 경우(페이지 이탈) 예외를 무시
            }
            await _module.DisposeAsync();
        }
    }
}
