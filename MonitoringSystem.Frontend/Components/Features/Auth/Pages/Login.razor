@page "/login"
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>로그인</PageTitle>

<div class="login-container">
    <div class="login-card">
        <div class="auth-mode-switch mb-4">
            <button type="button" class="auth-mode-button @GetModeClass(false)" @onclick="ShowLoginMode">로그인</button>
            <button type="button" class="auth-mode-button @GetModeClass(true)" @onclick="ShowRegisterMode">회원가입</button>
        </div>

        <h2 class="login-title">모니터링 시스템</h2>
        <p class="login-subtitle">@(_isRegisterMode ? "새 계정을 만들어 바로 시작하세요" : "로그인이 필요합니다")</p>

        <EditForm Model="@CurrentModel" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />
            <ValidationSummary class="validation-summary mb-3" />

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger">@_errorMessage</div>
            }

            @if (!string.IsNullOrEmpty(_successMessage))
            {
                <div class="alert alert-success">@_successMessage</div>
            }

            <div class="mb-3">
                <label class="form-label">아이디</label>
                <InputText class="form-control" @bind-Value="CurrentModel.Username" placeholder="아이디 입력" />
                <ValidationMessage For="@(() => CurrentModel.Username)" />
            </div>

            <div class="mb-3">
                <label class="form-label">비밀번호</label>
                <InputText class="form-control" type="password" @bind-Value="CurrentModel.Password" placeholder="비밀번호 입력" />
                <ValidationMessage For="@(() => CurrentModel.Password)" />
            </div>

            @if (_isRegisterMode)
            {
                <div class="mb-3">
                    <label class="form-label">비밀번호 확인</label>
                    <InputText class="form-control" type="password" @bind-Value="_registerModel.ConfirmPassword" placeholder="비밀번호 다시 입력" />
                    <ValidationMessage For="@(() => _registerModel.ConfirmPassword)" />
                </div>
            }

            <button type="submit" class="btn btn-primary w-100" disabled="@_isLoading">
                @if (_isLoading)
                {
                    <span>@(_isRegisterMode ? "가입 처리 중..." : "로그인 중...")</span>
                }
                else
                {
                    <span>@(_isRegisterMode ? "회원가입" : "로그인")</span>
                }
            </button>
        </EditForm>

        <div class="login-hint mt-3 text-muted small">
            @if (_isRegisterMode)
            {
                <div>가입한 계정은 기본적으로 Operator 권한으로 생성됩니다.</div>
                <div>회원가입이 완료되면 바로 로그인 상태로 이동합니다.</div>
            }
            else
            {
                <div>테스트 계정: admin / admin123 (Admin)</div>
                <div>operator / op123 (Operator)</div>
            }
        </div>
    </div>
</div>

